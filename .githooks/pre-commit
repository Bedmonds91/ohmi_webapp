#!/bin/sh
# Injects the git tag + commits-since-tag into index.html before each commit.
# Format: v0.0.1+3  (tag + number of commits past that tag)

DESCRIBE=$(git describe --tags --long 2>/dev/null)
if [ -z "$DESCRIBE" ]; then
  VERSION="v0.0.0+0"
else
  # git describe --tags --long → v0.0.1-3-gf8a68c3
  TAG=$(echo "$DESCRIBE"     | sed 's/-[0-9]*-g[0-9a-f]*$//')
  COMMITS=$(echo "$DESCRIBE" | sed 's/.*-\([0-9]*\)-g[0-9a-f]*$/\1/')
  VERSION="${TAG}+${COMMITS}"
fi

sed -i '' "s|>v[^<]*</span>|>${VERSION}</span>|" index.html

git add index.html
